{
  "name": "youtube-time-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension that tracks active time spent on YouTube.",
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "git config core.hooksPath .githooks"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/chrome": "0.2.2",
    "@types/node": "26.1.1",
    "chokidar": "5.0.0",
    "esbuild": "0.28.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  }
}
