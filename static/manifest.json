{
  "manifest_version": 3,
  "name": "YouTube Time Tracker",
  "version": "0.1.0",
  "description": "Tracks active time spent on YouTube in the active browser tab.",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["tabs", "storage", "alarms", "idle"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "24": "icons/icon-24.png",
      "32": "icons/icon-32.png"
    },
    "default_popup": "popup.html",
    "default_title": "YouTube Time Tracker"
  },
  "commands": {
    "toggle-tracking": {
      "suggested_key": {
        "default": "Alt+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Pause or resume YouTube time tracking"
    }
  }
}
