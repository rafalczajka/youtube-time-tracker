{
  "manifest_version": 3,
  "name": "Browser Time Tracker",
  "version": "0.1.0",
  "description": "Tracks active time per domain and shows your top websites.",
  "minimum_chrome_version": "120",
  "permissions": ["tabs", "storage", "alarms", "idle"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Browser Time Tracker"
  }
}
